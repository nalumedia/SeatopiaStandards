{% comment %}
  ═══════════════════════════════════════════════════════════════
  SEATOPIA NUTRITION INTELLIGENCE PLATFORM — Shopify Liquid Section
  ═══════════════════════════════════════════════════════════════
  v1.0 · Apr 3, 2026 · Lab-verified data
  22 products · 14 species · 60+ independent lab tests
  Sources: Light Labs + Edacious

  DATA MODEL: Seatopia Omega Standard
  - All omega-3 stored as mg/100g (canonical)
  - Per-serving computed at render: mg_per_100g × (oz × 28.3495 / 100)
  - Total Omega-3 = EPA + DHA + ALA
  - Marine Omega = EPA + DHA (primary metric)

  INSTALL:
  1. Shopify Admin → Online Store → Themes → Edit Code
  2. Create: sections/omega-map.liquid
  3. Paste this file
  4. Add via theme editor or: {% section 'omega-map' %}
  ═══════════════════════════════════════════════════════════════
{% endcomment %}

{% stylesheet %}
.omega-map {
  --c: #335566; --ce: #4B7991; --m: #7BC3F3;
  --l: #F7EFE6; --w: #FFFFFF; --t: #D45A3C; --p: #EE7B30;
  --moss: #2e8b57; --deep: #1a3344;
  font-family: 'Karla', -apple-system, sans-serif;
  color: var(--c); max-width: 960px; margin: 0 auto; padding: 40px 20px;
}
.omega-map * { box-sizing: border-box; margin: 0; padding: 0; }
.om-h { text-align: center; margin-bottom: 32px; }
.om-h h2 { font-family: 'EB Garamond', serif; font-size: 36px; font-weight: 600; margin-bottom: 8px; }
.om-h p { font-size: 15px; color: var(--ce); max-width: 580px; margin: 0 auto; line-height: 1.5; }
.om-formula {
  display: inline-block; margin: 12px 0 4px; padding: 6px 16px;
  background: var(--w); border-radius: 6px; font-size: 13px; font-weight: 600;
  box-shadow: 0 2px 6px rgba(51,85,102,0.06);
}
.om-note { font-size: 11px; color: #999; font-style: italic; margin-top: 6px; }
.om-ctrl { display: flex; justify-content: center; gap: 16px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }
.om-tog { display: inline-flex; background: var(--l); border-radius: 6px; padding: 3px; }
.om-tog button {
  padding: 8px 16px; font-size: 13px; font-weight: 600; font-family: inherit;
  border: none; border-radius: 4px; cursor: pointer; background: transparent;
  color: var(--ce); transition: all 0.2s;
}
.om-tog button.active { background: var(--c); color: var(--w); }
.om-stat { font-size: 13px; color: var(--ce); }
.om-stat strong { color: var(--c); }
.om-leg { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; font-size: 12px; color: var(--ce); }
.om-leg-i { display: flex; align-items: center; gap: 6px; }
.om-sw { width: 12px; height: 12px; border-radius: 2px; flex-shrink: 0; }
.om-tabs { display: flex; justify-content: center; gap: 0; margin-bottom: 24px; }
.om-tab {
  padding: 10px 20px; font-size: 12px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 1px; color: var(--ce); cursor: pointer; border-bottom: 2px solid transparent;
}
.om-tab:hover { color: var(--c); }
.om-tab.active { color: var(--c); border-bottom-color: var(--t); }
/* Sort buttons */
.om-sorts { display: flex; justify-content: center; gap: 6px; margin-bottom: 16px; flex-wrap: wrap; }
.om-sort-btn {
  padding: 5px 14px; font-size: 11px; font-weight: 600; font-family: inherit;
  border: 1.5px solid rgba(51,85,102,0.12); border-radius: 14px; cursor: pointer;
  background: var(--w); color: var(--ce); transition: all 0.2s;
}
.om-sort-btn.active { background: var(--c); color: var(--w); border-color: var(--c); }
/* Chart rows */
.om-row { display: flex; align-items: center; margin-bottom: 8px; cursor: pointer; transition: transform 0.12s; }
.om-row:hover { transform: translateX(3px); }
.om-lbl { width: 210px; flex-shrink: 0; text-align: right; padding-right: 14px; }
.om-sp { font-weight: 600; font-size: 13px; line-height: 1.3; }
.om-fm { font-size: 11px; color: var(--ce); }
.om-bw {
  flex: 1; height: 38px; background: rgba(75,121,145,0.05);
  border-radius: 6px; position: relative; overflow: visible;
}
.om-bar { height: 100%; border-radius: 6px; display: flex; overflow: hidden; transition: width 0.5s ease; }
.om-bar-epa { height:100%; background:var(--c); display:flex; align-items:center; justify-content:center; min-width:0; }
.om-bar-epa:first-child { border-radius: 6px 0 0 6px; }
.om-bar-dha { height:100%; background:var(--ce); display:flex; align-items:center; justify-content:center; min-width:0; }
.om-bar-ala { height:100%; background:var(--m); border-radius:0 6px 6px 0; display:flex; align-items:center; justify-content:center; min-width:0; opacity:0.5; }
.om-sl { font-size:10px; font-weight:700; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; padding:0 5px; }
.om-val {
  position: absolute; right: 0; top: 50%;
  transform: translate(calc(100% + 10px), -50%);
  font-size: 13px; font-weight: 700; white-space: nowrap;
}
.om-pills {
  display: flex; gap: 4px; flex-wrap: wrap; margin-top: 2px;
}
.om-pill {
  font-size: 9px; font-weight: 600; padding: 2px 7px; border-radius: 8px;
  white-space: nowrap;
}
.om-pill-pro { background: rgba(51,85,102,0.06); color: var(--c); }
.om-pill-se { background: rgba(46,139,87,0.08); color: var(--moss); }
.om-pill-hg { padding: 2px 7px; border-radius: 8px; font-size: 9px; font-weight: 600; }
.om-pill-mp { background: rgba(46,139,87,0.08); color: var(--moss); font-size: 9px; font-weight: 600; padding: 2px 7px; border-radius: 8px; }
.om-verified {
  display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 600;
  color: var(--moss); margin-top: 3px;
}
.om-verified a { color: var(--ce); text-decoration: underline; text-underline-offset: 2px; }
.om-verified a:hover { color: var(--c); }
.om-verified svg { width: 12px; height: 12px; flex-shrink: 0; }
.om-ts { width: 50px; flex-shrink: 0; text-align: center; margin-left: 70px; font-size: 10px; color: var(--ce); }
.om-ts strong { display: block; font-size: 14px; color: var(--c); }
/* Detail panel */
.om-det {
  display: none; background: var(--w); border-radius: 10px; padding: 24px;
  margin: 8px 0 16px 210px; box-shadow: 0 4px 16px rgba(51,85,102,0.08);
  animation: omFade 0.2s ease;
}
.om-det.open { display: block; }
@keyframes omFade { from { opacity:0; transform:translateY(-4px); } to { opacity:1; } }
.om-det-g { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; text-align: center; }
.om-det-b { padding: 14px; background: var(--l); border-radius: 8px; }
.om-det-b .lb { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; margin-bottom: 4px; }
.om-det-b .lb.epa { color: var(--c); }
.om-det-b .lb.dha { color: var(--ce); }
.om-det-b .lb.ala { color: #5a9ec8; }
.om-det-b .nm { font-family: 'EB Garamond', serif; font-size: 28px; font-weight: 600; }
.om-det-b .un { font-size: 11px; color: var(--ce); }
.om-det-m { margin-top: 12px; font-size: 11px; color: var(--ce); text-align: center; }
.om-det-nutri { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
.om-det-nut { text-align: center; padding: 8px; background: rgba(51,85,102,0.03); border-radius: 6px; }
.om-det-nut .dl { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--ce); font-weight: 600; }
.om-det-nut .dv { font-size: 16px; font-weight: 700; color: var(--c); }
.om-det-nut .du { font-size: 10px; color: #999; }
/* Data table */
.om-tbl-wrap { overflow-x: auto; }
.om-tbl {
  width: 100%; border-collapse: separate; border-spacing: 0;
  background: var(--w); border-radius: 10px; box-shadow: 0 2px 12px rgba(51,85,102,0.06);
  font-size: 13px;
}
.om-tbl thead th {
  background: var(--c); color: var(--w); padding: 10px 14px; text-align: left;
  font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.8px;
  white-space: nowrap; cursor: pointer;
}
.om-tbl thead th:first-child { border-radius: 10px 0 0 0; }
.om-tbl thead th:last-child { border-radius: 0 10px 0 0; }
.om-tbl td { padding: 8px 14px; border-bottom: 1px solid rgba(51,85,102,0.06); }
.om-tbl tr:hover { background: rgba(123,195,243,0.06); }
.om-tbl .n { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; }
.om-search-bar { display: flex; gap: 10px; margin-bottom: 16px; align-items: center; }
.om-search {
  flex: 1; padding: 8px 14px; border: 1.5px solid rgba(51,85,102,0.12); border-radius: 8px;
  font-size: 13px; font-family: inherit;
}
.om-export-btn {
  padding: 8px 16px; background: var(--c); color: var(--w); border: none; border-radius: 8px;
  font-size: 12px; font-weight: 600; font-family: inherit; cursor: pointer;
}
@media (max-width: 640px) {
  .om-lbl { width: 140px; }
  .om-sp { font-size: 11px; }
  .om-ts { width: 36px; margin-left: 36px; }
  .om-det { margin-left: 0; }
  .om-det-g { grid-template-columns: 1fr; }
  .om-det-nutri { grid-template-columns: 1fr 1fr; }
  .om-h h2 { font-size: 28px; }
}
{% endstylesheet %}

<div class="omega-map" id="omega-map-root">
  <div class="om-h">
    <h2>{{ section.settings.heading | default: 'Omega-3 Map' }}</h2>
    <p>{{ section.settings.subheading | default: 'Compare marine omega-3 density across our regenerative seafood catalog. All values from third-party lab testing.' }}</p>
    <div class="om-formula">Marine Omega = EPA + DHA &nbsp;·&nbsp; Total Omega-3 = EPA + DHA + ALA</div>
    <div class="om-note">Based on third-party lab averages · v1.0 · Apr 2026</div>
  </div>
  <div class="om-ctrl">
    <div class="om-tog" id="om-basis-tog">
      <button class="active" onclick="omBasis('standard',this)">Per 6 oz (Standardized)</button>
      <button onclick="omBasis('actual',this)">Per Actual Serving</button>
    </div>
    <div class="om-stat" id="om-stat"></div>
  </div>
  <div class="om-sorts" id="om-sorts">
    <button class="om-sort-btn active" onclick="omSortBy('epa_dha',this)">EPA + DHA</button>
    <button class="om-sort-btn" onclick="omSortBy('total',this)">Total Omega-3</button>
    <button class="om-sort-btn" onclick="omSortBy('epa',this)">EPA Only</button>
    <button class="om-sort-btn" onclick="omSortBy('dha',this)">DHA Only</button>
  </div>
  <div class="om-tabs">
    <div class="om-tab active" onclick="omTab('chart',this)">Chart</div>
    <div class="om-tab" onclick="omTab('table',this)">Data</div>
  </div>
  <div class="om-leg">
    <div class="om-leg-i"><div class="om-sw" style="background:#335566"></div> EPA</div>
    <div class="om-leg-i"><div class="om-sw" style="background:#4B7991"></div> DHA</div>
    <div class="om-leg-i"><div class="om-sw" style="background:#7BC3F3;opacity:0.5"></div> ALA</div>
  </div>
  <div id="om-chart"></div>
  <div id="om-table" style="display:none"></div>
</div>

{% javascript %}
(function(){
  // ═══════════════════════════════════════════════════════════
  // SEATOPIA OMEGA STANDARD — Canonical per-100g data (mg/100g)
