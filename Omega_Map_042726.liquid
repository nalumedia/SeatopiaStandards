     per100g:{e:376,d:1040,a:1620},pro:19.5,se:17.7,hg:10.57,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/hudson-valley-steelhead-trout-fillet",coaLabel:"Edacious"},
