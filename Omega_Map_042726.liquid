    {s:"King Salmon",f:"Big Glory Bay",oz:8,src:"Edacious",n:3,
     per100g:{e:546,d:885,a:1050},pro:18.9,se:31.4,hg:18.74,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/big-glory-bay-king-salmon-fillet",coaLabel:"Edacious"},
    {s:"Atlantic Salmon",f:"Bakkafrost",oz:6,src:"Edacious",n:6,
     per100g:{e:471,d:833,a:950},pro:21.3,se:18.6,hg:37.46,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/bakkafrost-atlantic-salmon-fillet",coaLabel:"Edacious"},
    {s:"Steelhead Trout",f:"Caleta Bay",oz:6,src:"Edacious",n:4,
     per100g:{e:262,d:589,a:1330},pro:20.8,se:22.1,hg:0,hgLoq:true,hgSrc:"Light Labs",mp:null,
     coa:"https://eat.edacious.com/brand/seatopia/caleta-bay-steelhead-trout-loin",coaLabel:"Edacious"},
    {s:"King Salmon",f:"Regal",oz:7.5,src:"Light Labs",n:1,
     per100g:{e:275.8,d:750.1,a:999},pro:20.77,se:36.68,hg:26.87,hgSrc:"Light Labs",mp:"ND",
     coa:null,coaLabel:"Light Labs COA on file"},
    {s:"Osetra Caviar",f:"Marshallberg",oz:1,src:"Light Labs",n:1,
     per100g:{e:497.8,d:1250.7,a:161.7},pro:26.11,se:63.3,hg:4.94,hgSrc:"Light Labs",mp:"ND",
     coa:null,coaLabel:"Light Labs COA on file"},
    {s:"Branzino",f:"Esteros Lubimar",oz:6,src:"Edacious",n:8,
     per100g:{e:304,d:598,a:880},pro:21.1,se:18.1,hg:100,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/esteros-lubimar-branzino-fillet",coaLabel:"Edacious"},
    {s:"Sea Bream",f:"Esteros Lubimar",oz:6,src:"Edacious",n:8,
     per100g:{e:221,d:567,a:643},pro:21.1,se:18.9,hg:60,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/esteros-lubimar-sea-bream-fillet",coaLabel:"Edacious"},
    {s:"Salmon Roe Caviar",f:"Yarra Valley",oz:1,src:"Light Labs + Edacious",n:1,
     per100g:{e:513.8,d:2292.4,a:142.4},pro:26.1,se:99.1,hg:0,hgLoq:true,hgSrc:"Light Labs",mp:"ND",
     coa:"https://app.edacious.com/app/products/f3129c49-1493-4e4d-8cad-dc3da201b91a/preview",coaLabel:"Edacious"},
    {s:"Rainbow Trout",f:"McFarland Springs",oz:6,src:"Edacious",n:2,
     per100g:{e:272,d:668,a:1270},pro:22.0,se:32.9,hg:9.41,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/mcfarland-springs-rainbow-trout",coaLabel:"Edacious Verified"},
    {s:"Yellowtail",f:"The Kingfish Co.",oz:6,src:"Edacious",n:2,
     per100g:{e:187,d:546,a:156},pro:23.4,se:21.5,hg:60.26,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/yellowtail-sashimi-loin",coaLabel:"Edacious Verified"},
    {s:"Rainbow Trout",f:"Smoke in Chimneys",oz:6,src:"Light Labs",n:1,
     per100g:{e:86,d:404,a:33},pro:18.2,se:17.15,hg:9.74,hgSrc:"Light Labs",mp:"ND",
     coa:null,coaLabel:"Light Labs COA on file"},
    {s:"Barramundi",f:"Australis",oz:6,src:"Edacious",n:2,
     per100g:{e:31,d:92,a:33},pro:21.0,se:23.0,hg:27.89,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/barramundi",coaLabel:"Edacious Verified"},
    {s:"Black Tiger Shrimp",f:"Tarakan",oz:4,src:"Edacious",n:2,
     per100g:{e:15,d:17,a:7},pro:18.0,se:13.5,hg:17.93,hgSrc:"Light Labs",mp:null,
     coa:"https://eat.edacious.com/brand/seatopia/mangrove-black-tiger-shrimp",coaLabel:"Edacious Verified"},
    {s:"Barramundi",f:"Desert Springs",oz:6,src:"Light Labs",n:1,
     per100g:{e:20,d:20,a:10},pro:18.4,se:20.81,hg:9.94,hgSrc:"Light Labs",mp:null,
     coa:null,coaLabel:"Light Labs COA on file"},
    {s:"Peruvian Scallops",f:"Seacorp",oz:4,src:"Edacious",n:2,
     per100g:{e:51,d:35,a:3},pro:14.4,se:11.1,hg:10,hgSrc:"Light Labs",mp:"ND",
     coa:"https://eat.edacious.com/brand/seatopia/half-shell-scallops",coaLabel:"Edacious Verified"}
  ];

  let basis='standard', openIdx=-1, view='chart', sortMetric='epa_dha';
  let sortK='total', sortA=false; // for table

  // Seatopia Omega Standard: compute per-serving from per-100g
  function serv(p) {
    const oz = basis === 'standard' ? STD_OZ : p.oz;
    const f = (oz * OZ_TO_G) / 100;
    const e = Math.round(p.per100g.e * f);
    const d = Math.round(p.per100g.d * f);
    const a = Math.round(p.per100g.a * f);
    return { e, d, a, ed: e+d, t: e+d+a, oz,
             pro: +(p.pro * f).toFixed(1),
             se: +(p.se * f).toFixed(1),
             hg: +((p.hg / 10) * f).toFixed(2) };
  }

  function sortVal(p) {
    const s = serv(p);
    if (sortMetric === 'epa_dha') return s.ed;
    if (sortMetric === 'epa') return s.e;
    if (sortMetric === 'dha') return s.d;
    return s.t;
  }

  function hgColor(mcg) {
    if (mcg < 0.5) return 'background:rgba(46,139,87,0.08);color:#2e8b57';
    if (mcg < 2) return 'background:rgba(238,123,48,0.1);color:#EE7B30';
    return 'background:rgba(238,28,37,0.1);color:#EE1C25';
  }

  function renderChart(){
    const sorted=[...P].sort((a,b)=>sortVal(b)-sortVal(a));
    const primaryKey = sortMetric === 'epa_dha' ? 'ed' : sortMetric === 'epa' ? 'e' : sortMetric === 'dha' ? 'd' : 't';
    const mx=Math.max(...sorted.map(p=>serv(p)[primaryKey]));
    let tt=0; sorted.forEach(p=>tt+=p.n);
    const basisLabel = basis === 'standard' ? 'per standardized 6 oz' : 'per actual serving';
    document.getElementById('om-stat').innerHTML='<strong>'+sorted.length+'</strong> products · <strong>'+tt+'</strong> tests · '+basisLabel;

    const showAla = sortMetric === 'total';

    let h='';
    sorted.forEach((p,i)=>{
      const d=serv(p);
      const primaryVal = d[primaryKey];
      const bw = Math.max((primaryVal/mx)*68, 2);

      let epPct, dhPct, alPct;
      if (sortMetric === 'epa') {
        epPct = 100; dhPct = 0; alPct = 0;
      } else if (sortMetric === 'dha') {
        epPct = 0; dhPct = 100; alPct = 0;
      } else if (sortMetric === 'epa_dha') {
        const sum = d.e + d.d;
        epPct = sum > 0 ? (d.e/sum*100) : 0;
        dhPct = sum > 0 ? (d.d/sum*100) : 0;
        alPct = 0;
      } else {
        epPct = d.t > 0 ? (d.e/d.t*100) : 0;
        dhPct = d.t > 0 ? (d.d/d.t*100) : 0;
        alPct = Math.max(0, 100 - epPct - dhPct);
      }

      const eL = epPct > 12 ? '<span class="om-sl">'+(sortMetric==='epa'?'EPA ':'')+d.e.toLocaleString()+'</span>' : '';
      const dL = dhPct > 14 ? '<span class="om-sl">'+(sortMetric==='dha'?'DHA ':'')+d.d.toLocaleString()+'</span>' : '';
      const aL = alPct > 14 && showAla ? '<span class="om-sl">'+d.a.toLocaleString()+'</span>' : '';
      const valLabel = sortMetric === 'epa_dha' ? d.ed.toLocaleString() + ' mg' :
                       sortMetric === 'epa' ? d.e.toLocaleString() + ' mg' :
                       sortMetric === 'dha' ? d.d.toLocaleString() + ' mg' :
                       d.t.toLocaleString() + ' mg';

      // Nutrient pills — public-facing: "Mercury Safe" instead of values, "Zero Detected Microplastics"
      const mpBadge = p.mp === 'ND' ? '<span class="om-pill om-pill-mp">Zero Detected Microplastics</span>' : '';

      // Verified badge with COA link
      const vSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>';
      let verifiedHtml = '<div class="om-verified">' + vSvg + ' 3rd Party Lab Verified';
      if (p.coa) {
        verifiedHtml += ' · <a href="' + p.coa + '" target="_blank" rel="noopener">View Results</a>';
      } else {
        verifiedHtml += ' · ' + p.coaLabel;
      }
      verifiedHtml += '</div>';

      let pills = '<div class="om-pills">'
        + '<span class="om-pill om-pill-pro">' + d.pro + 'g pro</span>'
        + '<span class="om-pill om-pill-se">' + d.se.toFixed(0) + ' mcg Se</span>'
        + '<span class="om-pill om-pill-hg" style="background:rgba(46,139,87,0.08);color:#2e8b57">Mercury Safe</span>'
        + mpBadge
        + '</div>'
        + verifiedHtml;

      h+='<div class="om-row" onclick="omDet('+i+')">'
        +'<div class="om-lbl"><div class="om-sp">'+p.s+', '+p.f+'</div><div class="om-fm">'+d.oz+' oz serving</div>'+pills+'</div>'
        +'<div class="om-bw"><div class="om-bar" style="width:'+bw+'%">'
        + (epPct > 0 ? '<div class="om-bar-epa" style="width:'+epPct+'%">'+eL+'</div>' : '')
        + (dhPct > 0 ? '<div class="om-bar-dha" style="width:'+dhPct+'%">'+dL+'</div>' : '')
        + (alPct > 0 && showAla ? '<div class="om-bar-ala" style="width:'+alPct+'%">'+aL+'</div>' : '')
        +'</div><div class="om-val">'+valLabel+'</div></div>'
        +'<div class="om-ts"><strong>'+p.n+'</strong>test'+(p.n>1?'s':'')+'</div></div>';

      // Detail panel
      h+='<div class="om-det" id="om-d-'+i+'">'
        +'<div class="om-det-g">'
        +'<div class="om-det-b"><div class="lb epa">EPA</div><div class="nm">'+d.e.toLocaleString()+'</div><div class="un">mg / '+d.oz+' oz</div></div>'
        +'<div class="om-det-b"><div class="lb dha">DHA</div><div class="nm">'+d.d.toLocaleString()+'</div><div class="un">mg / '+d.oz+' oz</div></div>'
        +'<div class="om-det-b"><div class="lb ala">ALA</div><div class="nm">'+d.a.toLocaleString()+'</div><div class="un">mg / '+d.oz+' oz</div></div>'
        +'</div>'
        +'<div class="om-det-nutri">'
        +'<div class="om-det-nut"><div class="dl">Protein</div><div class="dv">'+d.pro+'g</div></div>'
        +'<div class="om-det-nut"><div class="dl">Selenium</div><div class="dv">'+d.se.toFixed(0)+'</div><div class="du">mcg</div></div>'
        +'<div class="om-det-nut"><div class="dl">Mercury</div><div class="dv" style="color:#2e8b57">Safe</div><div class="du">tested by '+p.hgSrc+'</div></div>'
        +'<div class="om-det-nut"><div class="dl">Microplastics</div><div class="dv" style="color:#2e8b57">'+(p.mp==='ND'?'None Detected':'—')+'</div></div>'
        +'</div>'
        +'<div class="om-det-m">'+p.n+' test'+(p.n>1?'s':'')+' · '+p.f+' · '+p.src+' · '
        +(basis==='standard'?'Standardized 6 oz':'Actual '+p.oz+' oz serving')
        +'</div>'
        +'<div style="text-align:center;margin-top:10px">'
        +'<span class="om-verified" style="font-size:11px">' + vSvg + ' 3rd Party Lab Verified'
        +(p.coa ? ' · <a href="'+p.coa+'" target="_blank" rel="noopener" style="font-size:11px">View Full Lab Results →</a>' : ' · '+p.coaLabel)
        +'</span></div></div>';
    });
    document.getElementById('om-chart').innerHTML=h;
  }

  function renderTable(){
    let rows=[];
    P.forEach(p=>{
      const d = serv(p);
      rows.push({s:p.s, f:p.f, src:p.src, oz:d.oz, e:d.e, d:d.d, a:d.a, ed:d.ed, t:d.t,
                 pro:d.pro, se:d.se, hg:p.hg, hgSrc:p.hgSrc, hgLoq:p.hgLoq, n:p.n, mp:p.mp,
                 total:d.t, epa_dha:d.ed});
    });
    rows.sort((a,b)=>{
      let va=a[sortK],vb=b[sortK];
      if(typeof va==='string'){va=va.toLowerCase();vb=vb.toLowerCase();}
      return sortA?(va<vb?-1:va>vb?1:0):(va>vb?-1:va<vb?1:0);
    });

    let h='<div class="om-search-bar">'
      +'<input class="om-search" placeholder="Search products..." oninput="omFilter(this.value)">'
      +'<button class="om-export-btn" onclick="omExport()">Export CSV</button></div>';

    h+='<div class="om-tbl-wrap"><table class="om-tbl"><thead><tr>';
    [{k:'s',l:'Species'},{k:'f',l:'Farm'},{k:'src',l:'Lab'},{k:'oz',l:'Serving'},{k:'ed',l:'EPA+DHA'},{k:'e',l:'EPA'},{k:'d',l:'DHA'},{k:'a',l:'ALA'},{k:'t',l:'Total'},{k:'pro',l:'Protein'},{k:'se',l:'Se'},{k:'hg',l:'Mercury'},{k:'mp',l:'Microplastics'}].forEach(c=>{
      h+='<th onclick="omTSort(\''+c.k+'\')">'+c.l+(sortK===c.k?(sortA?' ▲':' ▼'):' ⇅')+'</th>';
    });
    h+='</tr></thead><tbody>';
    rows.forEach(r=>{
      h+='<tr class="om-tbl-row"><td><strong>'+r.s+'</strong></td><td style="color:var(--ce)">'+r.f+'</td><td>'+r.src+'</td><td>'+r.oz+' oz</td>'
        +'<td class="n" style="font-weight:700">'+r.ed.toLocaleString()+'</td>'
        +'<td class="n">'+r.e.toLocaleString()+'</td><td class="n">'+r.d.toLocaleString()+'</td><td class="n">'+r.a.toLocaleString()+'</td>'
        +'<td class="n">'+r.t.toLocaleString()+'</td>'
        +'<td class="n">'+r.pro+'g</td>'
        +'<td class="n">'+r.se.toFixed(0)+'</td>'
        +'<td style="color:#2e8b57;font-weight:600;text-align:center">Safe</td>'
        +'<td>'+(r.mp==='ND'?'<span style="color:#2e8b57;font-weight:600">None Detected</span>':'—')+'</td></tr>';
    });
    h+='</tbody></table></div>';
    document.getElementById('om-table').innerHTML=h;
  }

  function render(){renderChart();renderTable();}

  window.omBasis=function(b,btn){
    basis=b;openIdx=-1;
    btn.parentElement.querySelectorAll('button').forEach(x=>x.classList.remove('active'));
    btn.classList.add('active');render();
  };
  window.omSortBy=function(m,btn){
    sortMetric=m;openIdx=-1;
    document.querySelectorAll('.om-sort-btn').forEach(x=>x.classList.remove('active'));
    btn.classList.add('active');render();
  };
  window.omDet=function(i){
    document.querySelectorAll('.om-det.open').forEach(d=>d.classList.remove('open'));
    if(openIdx===i){openIdx=-1;return;}openIdx=i;
    var el=document.getElementById('om-d-'+i);if(el)el.classList.add('open');
  };
  window.omTab=function(v,btn){
    view=v;
    btn.parentElement.querySelectorAll('.om-tab').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('om-chart').style.display=v==='chart'?'':'none';
    document.getElementById('om-table').style.display=v==='table'?'':'none';
    document.getElementById('om-sorts').style.display=v==='chart'?'':'none';
  };
  window.omTSort=function(k){if(sortK===k)sortA=!sortA;else{sortK=k;sortA=k==='s'||k==='f';}renderTable();};
  window.omFilter=function(q){
    q=q.toLowerCase();
    document.querySelectorAll('.om-tbl-row').forEach(tr=>{
      tr.style.display=!q||tr.textContent.toLowerCase().includes(q)?'':'none';
    });
  };
  window.omExport=function(){
    const bLabel = basis==='standard'?'6oz_std':'actual';
    const headers=['Species','Farm','Lab','Serving_oz','EPA+DHA_mg','EPA_mg','DHA_mg','ALA_mg','Total_mg','Protein_g','Se_mcg','Mercury','Microplastics'];
    const rows=P.map(p=>{
      const d=serv(p);
      return [p.s,p.f,p.src,d.oz,d.ed,d.e,d.d,d.a,d.t,d.pro,d.se.toFixed(1),'Safe',p.mp==='ND'?'None Detected':'Not tested'].join(',');
    });
    const csv=headers.join(',')+'\n'+rows.join('\n');
    const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);
    a.download='seatopia_omega3_data_'+bLabel+'.csv';a.click();
  };

  render();
})();
{% endjavascript %}

{% schema %}
{
  "name": "Omega-3 Map",
  "tag": "section",
  "class": "omega-map-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Omega-3 Map" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Compare marine omega-3 density across our regenerative seafood catalog. All values from third-party lab testing." }
  ],
  "presets": [{ "name": "Omega-3 Map", "category": "Seatopia" }]
}
{% endschema %}
